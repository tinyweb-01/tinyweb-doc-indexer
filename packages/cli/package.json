{
  "name": "@tinyweb_dev/doc-indexer-cli",
  "version": "0.0.1",
  "description": "CLI for @tinyweb_dev/doc-indexer.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "doc-index": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tinyweb_dev/doc-indexer-core": "workspace:*",
    "@tinyweb_dev/doc-indexer-excel": "workspace:*",
    "@tinyweb_dev/doc-indexer-pdf": "workspace:*",
    "@tinyweb_dev/doc-indexer-llm-openai": "workspace:*",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  }
}
