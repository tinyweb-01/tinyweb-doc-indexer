{
  "name": "@tinyweb_dev/doc-indexer-core",
  "version": "0.0.2",
  "description": "Core pipeline + types for @tinyweb_dev/doc-indexer.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyweb-01/tinyweb-doc-indexer.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tinyweb-01/tinyweb-doc-indexer/tree/main/packages/core#readme",
  "bugs": "https://github.com/tinyweb-01/tinyweb-doc-indexer/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  }
}
