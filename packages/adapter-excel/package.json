{
  "name": "@tinyweb_dev/doc-indexer-excel",
  "version": "0.0.1",
  "description": "Excel / xlsx adapter for @tinyweb_dev/doc-indexer.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyweb-01/tinyweb-doc-indexer.git",
    "directory": "packages/adapter-excel"
  },
  "homepage": "https://github.com/tinyweb-01/tinyweb-doc-indexer/tree/main/packages/adapter-excel#readme",
  "bugs": "https://github.com/tinyweb-01/tinyweb-doc-indexer/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tinyweb_dev/doc-indexer-core": "workspace:*",
    "tinyweb-office-cells": "^1.2.3"
  },
  "optionalDependencies": {
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  }
}
